# Baseline versions for PR/push CI (reproducible builds). Renovate watches these lines
# and raises dashboard entries when new releases appear; the weekly cron independently
# validates against the LIVE latest platform regardless of this file.
# QUARKUS_LANGCHAIN4J_BOM_VERSION is a release-watcher entry only (the platform BOM
# already governs the extension version at build time).

# renovate: datasource=maven depName=io.quarkus.platform:quarkus-bom
QUARKUS_PLATFORM_VERSION=3.37.2
# renovate: datasource=maven depName=io.quarkiverse.langchain4j:quarkus-langchain4j-bom
QUARKUS_LANGCHAIN4J_BOM_VERSION=1.12.0
# renovate: datasource=java-version depName=java-jdk
JAVA_VERSION=25
