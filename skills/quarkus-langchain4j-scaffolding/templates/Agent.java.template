public record CategoryReport(String category, String reason) {}

/* ===================== File: dto/PriorityReport.java ===================== */
package org.acme.dto;

public record PriorityReport(String level, String reason) {}

/* ===================== File: dto/TriageReport.java ===================== */
package org.acme.dto;

public record TriageReport(CategoryReport category, PriorityReport priority, String recommendation) {}

/* ===================== File: dto/ProgressUpdate.java ===================== */
package org.acme.dto;

/** Event/step type streamed to the client. A sealed hierarchy is a good fit as this grows. */
public record ProgressUpdate(String state, TriageReport result, String error) {
    public static ProgressUpdate started()              { return new ProgressUpdate("STARTED", null, null); }
    public static ProgressUpdate done(TriageReport r)   { return new ProgressUpdate("DONE", r, null); }
    public static ProgressUpdate error(String message)  { return new ProgressUpdate("ERROR", null, message); }
}

