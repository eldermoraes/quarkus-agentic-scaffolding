package org.acme.ai;

import org.acme.dto.CategoryReport;
import dev.langchain4j.agentic.Agent;
import dev.langchain4j.service.SystemMessage;
import dev.langchain4j.service.UserMessage;
import dev.langchain4j.service.V;
import io.quarkiverse.langchain4j.RegisterAiService;
import jakarta.enterprise.context.ApplicationScoped;

@ApplicationScoped
@RegisterAiService(modelName = "smaller")
public interface CategoryAnalyzer {

    @SystemMessage("You classify support tickets. Return the category and a one-sentence reason.")
    @UserMessage("Ticket:\n{ticket}")
    @Agent(name = "category", description = "Classifies the ticket category", outputKey = "category")
    CategoryReport analyze(@V("ticket") String ticket);
}

