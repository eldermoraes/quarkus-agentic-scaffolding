# ============================================================================
# Quarkus + LangChain4j configuration
#
# Provider: Ollama, local-first. Requires a running Ollama (`ollama serve`,
# default endpoint http://localhost:11434) and the model pulled locally:
#   ollama pull llama3.2
#   ollama pull llama3.2:1b
# Models with >= 3B parameters follow system prompts more reliably; llama3.2 (3B)
# is a good default for structured output and agents.
# ============================================================================

# --- Ollama endpoint (uncomment to override the default) ---
# quarkus.langchain4j.ollama.base-url=http://localhost:11434

# --- Default chat model ---
quarkus.langchain4j.ollama.chat-model.model-id=llama3.2
quarkus.langchain4j.ollama.chat-model.temperature=0.7
quarkus.langchain4j.timeout=120s

# --- Named "smaller" model: cheap/fast subtasks (classification, query rewriting). ---
# Select it with @RegisterAiService(modelName = "smaller") or @ModelName("smaller").
# Use temperature 0 for deterministic, structured results.
quarkus.langchain4j.ollama.smaller.chat-model.model-id=llama3.2:1b
quarkus.langchain4j.ollama.smaller.chat-model.temperature=0
quarkus.langchain4j.ollama.smaller.chat-model.num-predict=1024
quarkus.langchain4j.ollama.smaller.timeout=60s

# --- Observability: log prompts and responses during development. ---
quarkus.langchain4j.log-requests=true
quarkus.langchain4j.log-responses=true

# --- Dev Services off: a real Ollama endpoint is configured above. ---
quarkus.langchain4j.devservices.enabled=false

# ============================================================================
# Cloud models (alternative to local). Requires an Ollama cloud account.
#   quarkus.langchain4j.ollama.chat-model.model-id=deepseek-v4-pro:cloud
#   quarkus.langchain4j.ollama.smaller.chat-model.model-id=gpt-oss:20b-cloud
# ============================================================================

# ============================================================================
# RAG (Easy RAG) — uncomment when the quarkus-langchain4j-easy-rag extension and
# an in-process embedding model (langchain4j-embeddings-all-minilm-l6-v2) are on
# the classpath. Documents in this folder are ingested into an in-memory store on
# startup; the in-process embedding model is detected automatically (no config).
# ============================================================================
# quarkus.langchain4j.easy-rag.path=src/main/resources/rag

# ============================================================================
# MCP client — uncomment when the langchain4j-mcp extension is present. Declares
# a named client ("ops") whose tools an AI service imports with @McpToolBox("ops").
# streamable-http is the recommended transport; stdio spawns a local server process.
# ============================================================================
# quarkus.langchain4j.mcp.ops.transport-type=streamable-http
# quarkus.langchain4j.mcp.ops.url=http://localhost:8081/mcp
## stdio alternative (local subprocess):
# quarkus.langchain4j.mcp.ops.transport-type=stdio
# quarkus.langchain4j.mcp.ops.command=npm,exec,@modelcontextprotocol/server-everything

# ============================================================================
# MCP server — uncomment when the mcp-server-http extension is present. The
# Streamable HTTP endpoint is served at /mcp by default. Traffic logging prints
# every JSON-RPC exchange during development.
# ============================================================================
# quarkus.mcp.server.http.root-path=/mcp
# quarkus.mcp.server.traffic-logging.enabled=true
# quarkus.mcp.server.traffic-logging.text-limit=500

# ============================================================================
# Observability — uncomment when quarkus-micrometer-registry-prometheus and
# quarkus-opentelemetry are on the classpath. AI-service metrics (incl. GenAI
# token usage gen_ai.client.token.usage) and per-service/per-tool spans are then
# emitted automatically; metrics are scraped at /q/metrics. Keys below only tune it.
# ============================================================================
## Ship traces to an OTLP collector (the default endpoint, shown explicitly):
# quarkus.otel.exporter.otlp.traces.endpoint=http://localhost:4317
## Dev-only: copy prompt/completion text onto spans (records user content):
# quarkus.langchain4j.tracing.include-prompt=true
# quarkus.langchain4j.tracing.include-completion=true
